{
  "name": "ludo-backend",
  "version": "1.0.0",
  "description": "Real-time multiplayer Ludo game backend with full user management",
  "main": "api/index.js",
  "scripts": {
    "start": "node api/index.js",
    "dev": "nodemon api/index.js",
    "dev:ts": "ts-node -r tsconfig-paths/register src/server.ts",
    "build": "tsc",
    "migration:run": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d src/config/database.ts",
    "migration:revert": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d src/config/database.ts"
  },
  "dependencies": {
    "@koa/cors": "^5.0.0",
    "@koa/router": "^12.0.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "firebase-admin": "^12.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.0",
    "koa": "^2.15.0",
    "koa-body": "^7.0.1",
    "koa-bodyparser": "^4.4.1",
    "koa-helmet": "^7.1.0",
    "koa-json": "^2.0.2",
    "koa-logger": "^3.2.1",
    "koa-static": "^5.0.0",
    "koa2-swagger-ui": "^5.12.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.8",
    "pg": "^8.20.0",
    "postgres": "^3.4.3",
    "redis": "^4.6.12",
    "reflect-metadata": "^0.2.1",
    "socket.io": "^4.7.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-koa": "^0.0.1",
    "typeorm": "^0.3.20",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/koa": "^2.15.0",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/koa-json": "^2.0.23",
    "@types/koa-logger": "^3.1.5",
    "@types/koa-static": "^4.0.4",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.14",
    "@types/uuid": "^9.0.7",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
