# Server
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# JWT (used by both Express game API and TypeScript services)
JWT_SECRET=change-this-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Database (for TypeScript Koa services, optional)
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=game_platform
# Or use SQLite:
# DB_TYPE=sqlite
# DB_SQLITE_PATH=./data/game_platform.sqlite

# Redis (for TypeScript Koa services, optional)
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# SMTP (for OTP emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=

# OTP
OTP_EXPIRY_MINUTES=5
